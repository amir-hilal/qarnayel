# ==============================================================================
# Qarnayel PUBLIC WEBSITE — ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# Copy this file to .env.local for local development
# NEVER commit .env.local, .env.staging, or .env.production
# All NEXT_PUBLIC_ vars are safe for client-side use (Firebase web SDK config)
# ==============================================================================

# ------------------------------------------------------------------------------
# Firebase Configuration (replace with values from Firebase Console)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here
# measurementId is optional and only needed if using Firebase Analytics
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# ------------------------------------------------------------------------------
# Site Configuration
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://qarnayel.lb
NEXT_PUBLIC_DEFAULT_LOCALE=ar

# ------------------------------------------------------------------------------
# Environment Identifier
# development | staging | production
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_ENV=development

# ------------------------------------------------------------------------------
# Firebase Emulator (set to true to use local emulators in development)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

# ------------------------------------------------------------------------------
# Firestore Database
# Leave empty (or omit) for the default (production) database.
# Set to "staging" for the named staging database.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=
