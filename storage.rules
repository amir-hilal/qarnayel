rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Public read — download URLs must work on the public website
      allow read: if true;

      // Authenticated write only — admin dashboard uploads
      // File size capped at 10 MB; only image MIME types accepted
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');

      // Authenticated delete — admin dashboard deletes
      allow delete: if request.auth != null;
    }
  }
}
